{
  "scripts": {
    "start": "parcel ./src/index.html",
    "build": "rm -rf build && parcel build -d build --public-url ./ --no-source-maps ./src/index.html",
    "test": "mocha -r ts-node/register tests/test.js",
    "zip": "rm -f bundle.zip && cd build && bestzip ../bundle.zip *",
    "bundle": "npm build && npm zip",
    "lint": "gts lint",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "npm run compile",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^9.0.0",
    "@types/node": "^22.7.5",
    "bestzip": "^2.2.0",
    "globals": "^17.5.0",
    "inquirer": "^13.4.1",
    "mocha": "^9.1.3",
    "parcel-bundler": "^1.12.5",
    "prettier": "^3.8.3",
    "sass": "^1.39.0",
    "ts-node": "^10.4.0",
    "typescript": "^5.6.3",
    "gts": "^7.0.0"
  }
}
