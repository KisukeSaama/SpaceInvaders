{
  "scripts": {
    "start": "parcel ./src/index.html",
    "build": "rm -rf build && parcel build -d build --public-url ./ --no-source-maps ./src/index.html",
    "test": "mocha -r ts-node/register tests/test.js",
    "zip": "rm -f bundle.zip && cd build && bestzip ../bundle.zip *",
    "bundle": "npm build && npm zip"
  },
  "devDependencies": {
    "bestzip": "^2.2.0",
    "parcel-bundler": "^1.12.5",
    "sass": "^1.39.0",
    "typescript": "^4.4.2",
    "mocha": "^9.1.3",
    "ts-node": "^10.4.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^16.11.7"
  }
}
